@page "/"
@using GestioPractiquesDuals.Application.Dashboard
@attribute [Authorize]
@inject GestioPractiquesDuals.Web.Services.DashboardApiClient DashboardApiClient

<PageTitle>Gestió de les pràctiques Duals</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="dashboard-shell">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dashboard-header">
        <MudText Typo="Typo.h3" Class="welcome-title">@_dashboard.WelcomeMessage</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Bookmarks">GESTIÓ DE CLASSES</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Add">NOVA ACTIVITAT</MudButton>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3" Class="kpi-grid">
        @foreach (var card in _dashboard.Stats)
        {
            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="stat-card pa-4">
                    <MudIcon Icon="@GetMaterialIcon(card.Icon)" Size="Size.Medium" Style="@($"color:{card.Color};")" />
                    <MudText Typo="Typo.h4" Style="@($"color:{card.Color};")">@card.Value</MudText>
                    <MudText Typo="Typo.body2">@card.Label</MudText>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <MudGrid Spacing="2" Class="filters-grid">
        <MudItem xs="12" md="3">
            <MudTextField T="string" Variant="Variant.Outlined" Placeholder="Cercar activitat" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedClass" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var className in _dashboard.AvailableClasses)
                {
                    <MudSelectItem T="string" Value="@className">@className</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedModule" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var moduleName in _dashboard.AvailableModules)
                {
                    <MudSelectItem T="string" Value="@moduleName">@moduleName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3" Class="toggle-zone">
            <MudSwitch T="bool" Label="Només obertes" Color="Color.Success" />
            <MudSwitch T="bool" Label="Arxivades" Color="Color.Default" />
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="section-title">
        <MudIcon Icon="@Icons.Material.Filled.LockOpen" Size="Size.Small" Style="color:#42c96d;" />
        Activitats obertes (@_dashboard.OpenActivities.Count)
    </MudText>

    <MudGrid Spacing="3">
        @foreach (var open in _dashboard.OpenActivities)
        {
            <MudItem xs="12" md="8" lg="6">
                <MudPaper Class="activity-card pa-4">
                    <MudText Typo="Typo.h5" Class="mb-1">@open.Code</MudText>
                    <MudText Typo="Typo.body2" Class="muted mb-4">@open.Subtitle</MudText>
                    <MudText Typo="Typo.body1" Class="mb-4">@open.Description</MudText>

                    <MudStack Row="true" Spacing="1" Class="mb-3">
                        @foreach (var chip in open.Chips)
                        {
                            <MudChip T="string" Variant="Variant.Outlined">@chip</MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(open.Highlight))
                        {
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled">@open.Highlight</MudChip>
                        }
                    </MudStack>

                    <div class="progress-rail">
                        <div class="progress-fill"></div>
                    </div>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-4">
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Text" Color="Color.Error">RESULTATS</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default">GRUPS</MudButton>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" />
                            <MudIconButton Icon="@Icons.Material.Filled.BarChart" Color="Color.Error" />
                            <MudIconButton Icon="@Icons.Material.Filled.Campaign" Color="Color.Info" />
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" />
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <MudText Typo="Typo.h5" Class="section-title closed-title">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Style="color:#73767d;" />
        Activitats tancades (@_dashboard.ClosedActivities.Count)
    </MudText>

    <MudGrid Spacing="3">
        @foreach (var closed in _dashboard.ClosedActivities)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudPaper Class="closed-card pa-4">
                    <MudText Typo="Typo.h6">@closed.Code</MudText>
                    <MudText Typo="Typo.body2">@closed.Title</MudText>
                    <MudText Typo="Typo.caption" Class="muted">@closed.Subtitle</MudText>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Style="color:#d84c3e;" />
                        <MudIcon Icon="@Icons.Material.Filled.MoreVert" />
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private string _selectedClass = "Totes les classes";
    private string _selectedModule = "Tots els mòduls";

    private DashboardSnapshotDto _dashboard =
        new(
            "Carregant dashboard...",
            Array.Empty<DashboardStatDto>(),
            ["Totes les classes"],
            ["Tots els mòduls"],
            Array.Empty<ActivityCardDto>(),
            Array.Empty<ActivityCardDto>());

    protected override async Task OnInitializedAsync()
    {
        _dashboard = await DashboardApiClient.GetTeacherPreviewAsync();
        _selectedClass = _dashboard.AvailableClasses.FirstOrDefault() ?? _selectedClass;
        _selectedModule = _dashboard.AvailableModules.FirstOrDefault() ?? _selectedModule;
    }

    private static string GetMaterialIcon(string iconName) =>
        iconName switch
        {
            "book" => Icons.Material.Filled.Book,
            "menu_book" => Icons.Material.Filled.MenuBook,
            "groups" => Icons.Material.Filled.Groups,
            "badge" => Icons.Material.Filled.Badge,
            "lock_open" => Icons.Material.Filled.LockOpen,
            "group_work" => Icons.Material.Filled.GroupWork,
            _ => Icons.Material.Filled.Circle
        };
}
