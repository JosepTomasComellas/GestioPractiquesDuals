@page "/login"
@attribute [AllowAnonymous]
@layout AuthLayout
@using GestioPractiquesDuals.Infrastructure.Options
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject Microsoft.Extensions.Options.IOptions<BootstrapAdminOptions> BootstrapAdminOptions

<PageTitle>Accés · Gestió de les pràctiques Duals</PageTitle>

<div class="login-page-shell">
    <section class="login-card">
        <header class="login-card-header">
            <div class="login-brand">
                <img src="/favicon.ico" alt="Salesians Sarrià" class="login-brand-logo" />
                <div class="login-brand-copy">
                    <div class="login-brand-title">salesians</div>
                    <div class="login-brand-subtitle">SARRIÀ</div>
                </div>
            </div>

            <h1 class="login-heading">Gestió de les pràctiques Duals</h1>
            <p class="login-subheading">Accés unificat per a professorat, gestió i alumnat.</p>
        </header>

        <main class="login-card-body">
            <form method="post" action="/auth/login" class="login-form-native">
                <input type="hidden" name="returnUrl" value="@CurrentReturnUrl" />

                <button type="button" class="access-mode access-mode-primary">
                    <span class="access-mode-icon material-icons">school</span>
                    <span>ACCÉS PROFESSORAT I GESTIÓ</span>
                </button>

                <div class="input-group">
                    <label for="login-email">Correu electrònic</label>
                    <input id="login-email"
                           name="email"
                           type="email"
                           autocomplete="username"
                           value="@PrefilledEmail"
                           placeholder="nom.cognom@sarria.salesians.cat" />
                </div>

                <div class="input-group">
                    <label for="login-password">Contrasenya</label>
                    <div class="password-wrapper">
                        <input id="login-password"
                               name="password"
                               type="@(_showPassword ? "text" : "password")"
                               autocomplete="current-password"
                               value="@PrefilledPassword"
                               placeholder="Introdueix la contrasenya" />
                        <button type="button" class="password-toggle" @onclick="TogglePassword" aria-label="Mostrar o ocultar contrasenya">
                            <span class="material-icons">@(_showPassword ? "visibility_off" : "visibility")</span>
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="login-error">@ErrorMessage</div>
                }

                <button type="submit" class="submit-button">ACCEDIR</button>
            </form>
        </main>

        <footer class="login-card-footer">
            <div class="login-footer-links">
                <div class="login-footer-link">
                    <span class="material-icons star">star</span>
                    <span>Seguiment</span>
                </div>
                <div class="login-footer-link">
                    <span class="material-icons groups">groups</span>
                    <span>Coordinació</span>
                </div>
                <div class="login-footer-link">
                    <span class="material-icons bar">bar_chart</span>
                    <span>Resultats</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(BootstrapAdminEmail))
            {
                <div class="login-footer-notes">
                    <div>Administrador inicial: <strong>@BootstrapAdminEmail</strong></div>
                    <div>Configurable des del fitxer <strong>.env</strong> del desplegament.</div>
                </div>
            }

            <div class="login-footer-meta">Salesians de Sarrià · Dept. d'Informàtica · @AppVersion</div>
        </footer>
    </section>
</div>

@code {
    private bool _showPassword;

    private string CurrentReturnUrl { get; set; } = "/";
    private string? ErrorMessage { get; set; }
    private string PrefilledEmail { get; set; } = string.Empty;
    private string PrefilledPassword { get; set; } = string.Empty;
    private string? BootstrapAdminEmail { get; set; }
    private string AppVersion =>
        $"V:{typeof(Program).Assembly.GetName().Version?.ToString(3) ?? "0.0.0"}";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("ReturnUrl", out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
        {
            CurrentReturnUrl = returnUrl.ToString();
        }

        if (query.TryGetValue("error", out var error) && !string.IsNullOrWhiteSpace(error))
        {
            ErrorMessage = error.ToString();
        }

        if (query.TryGetValue("email", out var email) && !string.IsNullOrWhiteSpace(email))
        {
            PrefilledEmail = email.ToString();
        }

        BootstrapAdminEmail = BootstrapAdminOptions.Value.Email;
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

}
