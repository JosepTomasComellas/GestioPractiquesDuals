@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Small" Class="py-10">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h5">Cal iniciar sessió</MudText>
        <MudText Typo="Typo.body1" Class="mt-2">S'està redirigint cap a la pantalla d'accés.</MudText>
    </MudPaper>
</MudContainer>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            NavigationManager.NavigateTo("/login", replace: true);
        }
    }
}
