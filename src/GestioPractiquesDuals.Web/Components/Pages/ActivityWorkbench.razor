@page "/activities"
@attribute [Authorize]

<PageTitle>Activitats · Gestió de les pràctiques Duals</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="activity-workbench-shell">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="activity-workbench-header">
        <div>
            <MudText Typo="Typo.h4" Class="activity-workbench-title">Activitats i seguiment</MudText>
            <MudText Typo="Typo.body1" Class="activity-workbench-subtitle">
                Vista resum del seguiment inicial d'alumnes, classes i cicles del curs actiu.
            </MudText>
        </div>

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Bookmarks" Href="/classes/manage">CLASSES</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Hub" Href="/cycles/manage">CICLES</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Dashboard" Href="/">DASHBOARD</MudButton>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <MudPaper Class="activity-board-card">
                <MudText Typo="Typo.h6" Class="board-title">Activitat oberta de referència</MudText>
                <MudText Typo="Typo.h4" Class="board-code">CV-001</MudText>
                <MudText Typo="Typo.body1" Class="board-subtitle">S1SX · Administració de sistemes · Tutor ASIX</MudText>
                <MudText Typo="Typo.body1" Class="board-description">
                    Seguiment inicial del procés d'enviament de currículums per a empreses actives.
                </MudText>

                <MudStack Row="true" Spacing="1" Class="board-chip-row">
                    <MudChip T="string" Variant="Variant.Outlined">1 grup</MudChip>
                    <MudChip T="string" Variant="Variant.Outlined">1 alumne</MudChip>
                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled">1 / 1 revisat</MudChip>
                </MudStack>

                <div class="board-progress">
                    <div class="board-progress-fill"></div>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="activity-side-card">
                <MudText Typo="Typo.h6" Class="board-title">Navegació principal</MudText>
                <ul class="test-list">
                    <li>Dashboard general del curs.</li>
                    <li>Gestió de classes i obertura del formulari.</li>
                    <li>Cicles i tutors del curs actiu.</li>
                    <li>Seguiment resumit de l'activitat oberta.</li>
                </ul>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
